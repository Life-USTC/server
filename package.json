{
  "name": "life-ustc-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "USTC Life Server - Course and schedule management API using SvelteKit",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13 <1.4"
  },
  "scripts": {
    "build": "bun --silent run tools/dev/build.ts",
    "dev": "bun run tools/dev/dev.ts",
    "format": "biome format",
    "health": "bun --silent run tools/dev/health.ts",
    "load:static": "bun run tools/load/load-from-static.ts",
    "prepare": "git config core.hooksPath .githooks",
    "db": "prisma",
    "release": "semantic-release",
    "seed": "bun run tools/dev/seed/seed-dev-scenarios.ts",
    "test": "bun --silent run tools/dev/quiet.ts -- vitest run",
    "verify": "bun --silent run tools/dev/verify.ts",
    "verify:full": "bun --silent run tools/dev/verify.ts full"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.11",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.17.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@scalar/api-reference": "^1.59.3",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.11",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "ical-generator": "^10.2.0",
    "jose": "^6.2.3",
    "katex": "^0.16.47",
    "pg": "^8.21.0",
    "pinyin-pro": "^3.28.1",
    "prisma": "7.8.0",
    "rehype-attr": "^4.1.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "bits-ui": "^2.18.1",
    "daisyui": "^5.5.23",
    "semantic-release": "24.2.9",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7",
    "wrangler": "4.100.0",
    "zod-openapi": "^6.0.0"
  }
}
